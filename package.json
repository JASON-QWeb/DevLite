{
  "name": "devlite",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "A lightweight inspection-mode Chrome extension for live page edits, data lookup, diagnostics, and repair prompt export.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build && node scripts/build-classic-scripts.mjs",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "qa": "npm run build && node scripts/qa-extension.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "readme:images": "npm run build && node scripts/generate-readme-covers.mjs",
    "store:images": "npm run build && node scripts/generate-store-images.mjs",
    "zip": "npm run build && rm -f devlite.zip && cd dist && zip -r ../devlite.zip ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.306",
    "@types/node": "^22.15.29",
    "esbuild": "^0.25.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
